"""`jena_dataset_library` — bundle RDF files into a java_library that loads
them into an Apache Jena `Model` from the classpath.

The Jena analog of resource-embedding: instead of a tool path-reading TTLs
from a working-directory-relative location at runtime, the RDF ships *inside*
the jar and a generated accessor loads it via `getResourceAsStream`. This is
how a spec ontology / vocabulary / fixture graph travels with the Java code
that needs it, with no kg-root assumption.

```python
load("@rules_jena//jena:defs.bzl", "jena_dataset_library")

jena_dataset_library(
    name = "vocab",
    srcs = ["rfc.ttl", "shapes.ttl"],
    package = "com.example.spec",
    classname = "Vocab",
)
# elsewhere:  Model m = com.example.spec.Vocab.load();
```

Generates `<package>.<classname>` with a static `Model load()` that reads
each src (bundled as a classpath resource at `/<basename>`) and unions them
into one Model. `srcs` must live in the calling package (their basenames
must be unique). Pairs naturally with rules_rdf's `rdf_dataset` — pass the
same files the dataset is declared over.
"""

load("@rules_java//java:defs.bzl", "java_library")

# Maven labels for the Jena read path (ARQ pulls core/base/iri transitively,
# but list them so the generated accessor compiles standalone).
_JENA_DEPS = [
    "@jena_maven//:org_apache_jena_jena_arq",
    "@jena_maven//:org_apache_jena_jena_core",
    "@jena_maven//:org_apache_jena_jena_base",
    "@jena_maven//:org_apache_jena_jena_iri",
]

# in_format → Jena Lang enum constant.
_LANG = {
    "turtle": "TURTLE",
    "ntriples": "NTRIPLES",
    "nquads": "NQUADS",
    "trig": "TRIG",
    "jsonld": "JSONLD",
    "rdfxml": "RDFXML",
}

_ACCESSOR_TEMPLATE = """package {package};

import java.io.InputStream;
import org.apache.jena.rdf.model.Model;
import org.apache.jena.rdf.model.ModelFactory;
import org.apache.jena.riot.Lang;
import org.apache.jena.riot.RDFDataMgr;

/**
 * Generated by rules_jena's jena_dataset_library. Loads the bundled RDF
 * resources into a Jena Model from the classpath — no working-directory or
 * kg-root assumption. Do not edit.
 */
public final class {classname} {{
    private {classname}() {{}}

    private static final String[] RESOURCES = {{ {resources} }};

    /** Read every bundled RDF resource into one unioned Model. */
    public static Model load() {{
        Model m = ModelFactory.createDefaultModel();
        for (String r : RESOURCES) {{
            try (InputStream in = {classname}.class.getResourceAsStream(r)) {{
                if (in == null) {{
                    throw new IllegalStateException("bundled RDF resource missing from classpath: " + r);
                }}
                RDFDataMgr.read(m, in, Lang.{lang});
            }} catch (java.io.IOException e) {{
                throw new RuntimeException("failed to read bundled RDF resource " + r, e);
            }}
        }}
        return m;
    }}
}}
"""

def jena_dataset_library(name, srcs, package, classname, in_format = "turtle", visibility = None):
    """A java_library bundling `srcs` as classpath resources + a generated
    `<package>.<classname>.load()` returning a Jena Model.

    Args:
      name: target name.
      srcs: RDF files (in the calling package; unique basenames). Same files
        an rdf_dataset would be declared over.
      package: Java package for the generated accessor.
      classname: Java class name for the generated accessor.
      in_format: serialization of every src (turtle/ntriples/nquads/trig/
        jsonld/rdfxml). One format per library.
      visibility: forwarded to the java_library.
    """
    if in_format not in _LANG:
        fail("jena_dataset_library: unsupported in_format %r (one of %s)" %
             (in_format, sorted(_LANG.keys())))

    basenames = [s.split(":")[-1].split("/")[-1] for s in srcs]
    resources = ", ".join(['"/%s"' % b for b in basenames])
    accessor = _ACCESSOR_TEMPLATE.format(
        package = package,
        classname = classname,
        resources = resources,
        lang = _LANG[in_format],
    )

    gen = "_{}_accessor".format(name)
    native.genrule(
        name = gen,
        outs = ["{}.java".format(classname)],
        # Write the generated source verbatim (single-quoted heredoc — no
        # shell expansion of the Java body).
        cmd = "cat > $@ <<'JENA_DATASET_LIBRARY_EOF'\n" + accessor + "\nJENA_DATASET_LIBRARY_EOF\n",
    )

    java_library(
        name = name,
        srcs = [":" + gen],
        resources = srcs,
        resource_strip_prefix = native.package_name(),
        deps = _JENA_DEPS,
        visibility = visibility,
    )
